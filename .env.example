# ============================================
# Agis Digital LP — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores.
# Estas variáveis são usadas APENAS no build (Vite embute nos JS estáticos).
# NUNCA coloque a SERVICE_ROLE_KEY aqui — ela é somente para o backend do Supabase.

# ── Supabase (chaves PÚBLICAS — seguras para o frontend) ──
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...sua_anon_key_aqui

# ── Porta da aplicação na VPS (padrão: 3000) ──
APP_PORT=3000
